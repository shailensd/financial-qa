# FinDoc Intelligence - Environment Configuration
# Copy this file to .env and fill in the required values

# =============================================================================
# REQUIRED CONFIGURATION
# =============================================================================

# PostgreSQL Database Connection
# Format: postgresql://username:password@host:port/database
# Example: postgresql://findoc_user:secure_password@localhost:5432/findoc_db
DATABASE_URL=postgresql://user:password@localhost:5432/findoc_intelligence

# Google Gemini API Key
# Get your API key from: https://ai.google.dev/
# Required for Gemini 2.0 Flash model
GEMINI_API_KEY=your_gemini_api_key_here


# =============================================================================
# OPTIONAL CONFIGURATION (defaults provided)
# =============================================================================

# Document Chunking Configuration
# CHUNK_SIZE: Number of words per chunk (default: 800)
# CHUNK_OVERLAP: Number of overlapping words between chunks (default: 200)
# CHUNK_SIZE=800
# CHUNK_OVERLAP=200

# Retrieval Configuration
# RETRIEVAL_TOP_K: Number of top chunks to retrieve per query (default: 10)
# RETRIEVAL_TOP_K=10

# Agent Pipeline Configuration
# MAX_REPAIR_ITERATIONS: Maximum number of Planner-Critic repair loops (default: 2)
# MEMORY_SUMMARIZATION_INTERVAL: Trigger memory summarization every N turns (default: 5)
# MEMORY_SUMMARY_MAX_WORDS: Maximum words in compressed memory summary (default: 150)
# MAX_REPAIR_ITERATIONS=2
# MEMORY_SUMMARIZATION_INTERVAL=5
# MEMORY_SUMMARY_MAX_WORDS=150

# ChromaDB Configuration
# CHROMA_PERSIST_DIR: Directory for ChromaDB vector store persistence (default: ./chroma_db)
# CHROMA_PERSIST_DIR=./chroma_db

# Ollama Configuration
# OLLAMA_BASE_URL: Base URL for local Ollama instance (default: http://localhost:11434)
# Note: Ollama is used for Llama 3.2 3B and Gemma 2 9B models (local only)
# OLLAMA_BASE_URL=http://localhost:11434

# Evaluation Configuration
# FEW_SHOT_DEDUP_THRESHOLD: Cosine similarity threshold for few-shot deduplication (default: 0.85)
# FEW_SHOT_DEDUP_THRESHOLD=0.85


# =============================================================================
# DEPLOYMENT NOTES
# =============================================================================

# Local Development:
# - Ensure PostgreSQL is running locally or use a cloud database
# - Install and run Ollama for local LLM models: https://ollama.ai/
# - Pull required models: ollama pull llama3.2:3b && ollama pull gemma2:9b

# Docker Deployment:
# - Use docker-compose.yml which includes PostgreSQL and ChromaDB services
# - Set DATABASE_URL to: postgresql://findoc_user:findoc_pass@postgres:5432/findoc_db
# - Set OLLAMA_BASE_URL to: http://host.docker.internal:11434 (if Ollama runs on host)

# Cloud Deployment (Railway/Render):
# - Ollama requires GPU and is not available in most cloud environments
# - System will use Gemini 2.0 Flash as the primary model
# - Ensure GEMINI_API_KEY is set in the platform's environment variables dashboard
# - Use the platform's managed PostgreSQL service for DATABASE_URL
